src/surface_misc_test.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/geometry-central-test.dir/build.make CMakeFiles/geometry-central-test.dir/src/surface_misc_test.cpp.i
.PHONY : src/surface_misc_test.cpp.i

src/surface_misc_test.s: src/surface_misc_test.cpp.s
.PHONY : src/surface_misc_test.s

# target to generate assembly for a file
src/surface_misc_test.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/geometry-central-test.dir/build.make CMakeFiles/geometry-central-test.dir/src/surface_misc_test.cpp.s
.PHONY : src/surface_misc_test.cpp.s

